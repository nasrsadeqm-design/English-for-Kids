rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "nasrsadeqm@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    // Activations Collection
    match /activations/{activationId} {
      // Students can only check if their specific code is already used
      // and create a new activation record if the code is valid.
      // They cannot list all activations.
      allow get: if true; 
      allow list: if isAdmin();
      
      allow create: if true; // Validation happens via studentId/code check in app logic
      allow update, delete: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
