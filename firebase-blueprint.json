{
  "entities": {
    "activation": {
      "title": "Activation Record",
      "description": "Records of student book activations tied to specific devices.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "The unique ID of the student (e.g., STU-0001)" },
        "activationCode": { "type": "string", "description": "The code used for activation" },
        "deviceFingerprint": { "type": "string", "description": "Unique hash of the device hardware/browser" },
        "activatedAt": { "type": "string", "format": "date-time", "description": "Timestamp of activation" }
      },
      "required": ["studentId", "activationCode", "deviceFingerprint", "activatedAt"]
    },
    "admin": {
      "title": "Admin User",
      "description": "Authorized administrator accounts.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin"] }
      }
    }
  },
  "firestore": {
    "/activations/{activationId}": {
      "schema": "activation",
      "description": "Collection of all activated licenses."
    }
  }
}
